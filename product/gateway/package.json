{
  "name": "@diagram-as-code/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "npm --workspace=@diagram-as-code/contracts run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --watch src/server.ts",
    "pretest": "npm run build",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "@diagram-as-code/contracts": "0.1.0",
    "fastify": "^5.6.0",
    "zod": "^4.1.0"
  }
}
