# Run `npm run key:generate --prefix .. -- local-admin`, store the plaintext key
# in the client secret store, and replace this value with the generated verifier record.
DIAGRAM_API_KEY_RECORDS=replace-with-generated-json-record
GATEWAY_PORT=9000
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
RENDER_MAX_CONCURRENT=4
RENDER_MAX_QUEUE=20
MAX_OUTPUT_BYTES=10485760

# Override these to test images built from your Kroki fork.
KROKI_IMAGE=yuzutech/kroki:0.31.1
MERMAID_IMAGE=yuzutech/kroki-mermaid:0.31.1
GATEWAY_IMAGE=diagram-as-code-gateway:local
