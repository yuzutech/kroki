{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  dependencyDashboard: true,
  labels: [
    '🔗 dependencies',
  ],
  separateMajorMinor: true,
  // wait at least 7 days after a release before proposing it
  minimumReleaseAge: '7 days',
  // batch all PRs on monday morning instead of creating them continuously
  timezone: 'Europe/Paris',
  schedule: [
    'before 6am on monday',
  ],
  // major updates wait for manual approval from the dependency dashboard
  major: {
    dependencyDashboardApproval: true,
  },
  // avoid PR bursts and cascading rebases
  prConcurrentLimit: 5,
  prHourlyLimit: 2,
  extends: [
    ':preserveSemverRanges',
  ],
  // security fixes should not wait
  vulnerabilityAlerts: {
    minimumReleaseAge: null,
  },
  packageRules: [
    {
      "matchManagers": ["cargo"],
      "groupName": "Rust crate",
      "versioning": "cargo",
      "rangeStrategy": "bump"
    },
    {
      matchManagers: [
        'github-actions',
      ],
      groupName: 'GitHub Actions',
    },
    {
      matchManagers: [
        'dockerfile',
      ],
      matchUpdateTypes: [
        'major',
      ],
      enabled: false,
      matchPackageNames: [
        '/node/',
      ],
    },
    {
      matchManagers: [
        'dockerfile',
      ],
      groupName: 'Docker images',
    },
    {
      matchManagers: [
        'pip_requirements',
      ],
      groupName: 'Python dependencies',
    },
    {
      matchManagers: [
        'npm',
      ],
      groupName: 'Node dependencies',
    },
    {
      matchManagers: [
        'npm',
      ],
      enabled: false,
      matchPackageNames: [
        '/puppeteer/',
      ],
    },
    {
      // lockfile regeneration resolves versions published at least 14 days ago
      // (Renovate passes --before to npm, covering transitive dependencies too)
      matchManagers: [
        'npm',
      ],
      matchUpdateTypes: [
        'lockFileMaintenance',
      ],
      minimumReleaseAge: '14 days',
    },
    {
      matchManagers: [
        'maven',
      ],
      groupName: 'Java dependencies',
    },
    {
      matchManagers: [
        'maven',
      ],
      groupName: 'Java testing packages',
      matchPackageNames: [
        '/^org.mockito/',
        '/^org.junit.jupiter/',
        '/^org.assertj/',
      ],
    },
    {
      matchManagers: [
        'maven',
      ],
      groupName: 'Maven plugins',
      matchPackageNames: [
        '/^org.apache.maven.plugins/',
      ],
    },
    {
      matchManagers: [
        'maven',
      ],
      groupName: 'Structurizr packages',
      matchPackageNames: [
        '/^com.structurizr/',
      ],
    },
    {
      matchManagers: [
        'maven',
      ],
      versioning: 'regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)?$',
      groupName: 'PlantUML',
      matchPackageNames: [
        '/plantuml/',
      ],
    },
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
}
